# Backend API Keys
# Get your DeepSeek API key from: https://api.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional: For future integrations
# NVIDIA_API_KEY=your_nvidia_api_key_here

# Backend Configuration
# BACKEND_PORT=8000
# DEBUG=False

# Frontend Configuration (if needed)
# VITE_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Email Intake Worker (backend/email_watcher)
# Watches a Gmail inbox and auto-evaluates emailed pre-work PDFs.
# ---------------------------------------------------------------------------

# Provider: "imap" (Gmail App Password) or "gmail_api" (OAuth2)
EMAIL_PROVIDER=imap

# Detection / processing
EMAIL_POLL_INTERVAL=60
EMAIL_EXPECTED_SUBJECT=Pre-Work Submission
# Naming convention: ng_<name>.pdf  (e.g. ng_aniket.pdf -> "Aniket")
EMAIL_FILENAME_REGEX=^ng_([a-zA-Z0-9]+(?:_[a-zA-Z0-9]+)*)\.pdf$

# Evaluation defaults (track is NOT parsed from the email)
DEFAULT_EMAIL_TRACK=ai
DEFAULT_EMAIL_EVAL_TYPE=prework

# --- IMAP provider (EMAIL_PROVIDER=imap) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_MAILBOX=INBOX
GMAIL_ADDRESS=your_inbox@gmail.com
# Create at: https://myaccount.google.com/apppasswords (requires 2FA)
GMAIL_APP_PASSWORD=your_16_char_app_password

# --- Gmail API provider (EMAIL_PROVIDER=gmail_api) ---
GMAIL_API_CREDENTIALS_PATH=credentials.json
GMAIL_API_TOKEN_PATH=token.json
GMAIL_USER_ID=me
